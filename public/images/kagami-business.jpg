        .challenge-footer .loading {
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255,255,255,0.2);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .challenge-footer .status { color: #aaa; }
        .challenge-footer .error { color: #ff4444; }
    </style>
</head>
